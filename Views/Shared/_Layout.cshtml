<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PC01_04</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PC01_04.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav style="
        display:flex;
        justify-content:space-between;
        align-items:center;
        padding:15px 25px;
        background:#ffffff;
        border-bottom:1px solid #ddd;
">

    <!-- Logo -->
    <div style="font-weight:bold; font-size:20px; color:#ff4d00;">
        <h1>Portal RetailCam 💼</h1>
    </div>

    <!-- Menú -->
    <div style="display:flex; gap:15px;">
        <a href="/Campanas"
        style="
        padding:8px 12px;
        border-radius:8px;
        text-decoration:none;
        background:#ff4d00;
        color:white;">
            📋 Listado
        </a>

        <a href="/Campanas"
           style="padding:8px 12px; border-radius:8px; text-decoration:none; color:black;">
            🔎 Filtrar
        </a>

        <a href="/Campanas/Resumen"
           style="padding:8px 12px; border-radius:8px; text-decoration:none; color:black;">
            📊 Resumen
        </a>

    </div>

</nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - PC01_04 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
