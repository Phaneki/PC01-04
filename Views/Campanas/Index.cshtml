@model List<PortalCampanas.Models.Campania>

<h2>Listado de Campañas</h2>
<form method="get">
    <label>Categoría:</label>
    <select name="categoria">
        <option value="">Todas</option>
        <option>Electro</option>
        <option>Hogar</option>
        <option>Moda</option>
        <option>Tecnología</option>
    </select>

    <label>Estado:</label>
    <select name="estado">
        <option value="">Todos</option>
        <option>Vigente</option>
        <option>Próxima</option>
        <option>Finalizada</option>
    </select>

    <button type="submit">Filtrar</button>
</form>
<table border="1">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Estado</th>
            <th>Canal</th>
            <th>Descuento</th>
            <th>Fechas</th>
        </tr>
    </thead>
    
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Nombre</td>
                <td>@c.Categoria</td>
                <td>@c.Estado</td>
                <td>@c.Canal</td>
                <td>@c.DescuentoPct %</td>
                <td>@c.FechaInicio.ToShortDateString() - @c.FechaFin.ToShortDateString()</td>
            </tr>
            <th>Acciones</th>
            <td>
                <a href="/Campanas/Detalle/@c.Id">Ver detalle</a>
            </td>
        }
    </tbody>
</table>