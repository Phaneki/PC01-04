<h2>Resumen de Campañas</h2>

<p>Total campañas: @ViewBag.Total</p>
<p>Vigentes: @ViewBag.Vigentes</p>
<p>Próximas: @ViewBag.Proximas</p>
<p>Promedio descuento: @ViewBag.Promedio %</p>

<h3>Cantidad por canal</h3>
<ul>
@foreach (var item in ViewBag.PorCanal)
{
    <li>@item.Canal: @item.Cantidad</li>
}
</ul>

<a href="/Campanas">Volver</a>